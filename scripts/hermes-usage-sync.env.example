# Copy this file to hermes-usage-sync.env and fill the values before enabling the cron job.
TOKEN_ANALYTICS_ENDPOINT=https://token-usage-analytics.tevpro.workers.dev/api/ingest/hermes-usage
TOKEN_ANALYTICS_INGEST_TOKEN=replace-me-with-the-worker-secret
TOKEN_ANALYTICS_DAYS_BACK=30
TOKEN_ANALYTICS_WORKSPACE_NAME=Hermes Usage
TOKEN_ANALYTICS_WORKSPACE_PROVIDER=Hermes
TOKEN_ANALYTICS_WORKSPACE_SLUG=hermes-usage
TOKEN_ANALYTICS_ENVIRONMENT=production
TOKEN_ANALYTICS_TIMEOUT=30
# Optional if state.db lives somewhere else:
# HERMES_STATE_DB=/home/hermes/.hermes/state.db
